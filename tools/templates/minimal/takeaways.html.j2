<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ data.title | em | striptags | default('要点') }} · 要点</title>
<style>
{% include 'minimal/_base.css' %}
.content {
  padding: 36px 56px 24px;
}

/* 顶部横向索引条 — 与 abstract 同源节律 */
.topline {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 18px;
  align-items: baseline;
  margin-bottom: 22px;
}
.topline .idx {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: 9.5px;
  letter-spacing: .46em;
  text-transform: uppercase;
  color: var(--ink);
}
.topline .midrule { height: 0; border-top: 0.5px solid var(--hair); align-self: center; }
.topline .num {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 144, "wght" 200;
  font-feature-settings: "onum" 1, "pnum" 0, "tnum" 1, "ss01" 1, "lnum" 0;
  font-size: 42px;
  line-height: 1;
  color: var(--ink);
  letter-spacing: -.02em;
}
.topline .num small {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: .22em;
  color: var(--ink-3);
  margin-left: 8px;
  vertical-align: 4px;
  font-weight: 400;
}

.hd {
  padding-bottom: 18px;
  margin-bottom: 8px;
  border-bottom: 0.5px solid var(--hair);
}
.hd h2 {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  font-size: 28px;
  line-height: 36px;
  color: var(--ink);
  letter-spacing: -.005em;
  max-width: 560px;
}
.hd h2 em {
  font-style: normal;
  border-bottom: 0.5px solid var(--accent);
  padding-bottom: 2px;
}

/* items — huge thin hanging numerals left, clean serif right */
.item {
  display: grid;
  grid-template-columns: 92px 1fr;
  gap: 24px;
  padding: 18px 0;
  border-bottom: 0.5px solid var(--hair);
  align-items: baseline;
}
.item:last-of-type { border-bottom: none; }

.item .num {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 144, "wght" 200;
  font-feature-settings: "onum" 1, "pnum" 0, "tnum" 1, "ss01" 1, "lnum" 0;
  font-size: 72px;
  line-height: 0.9;
  color: var(--ink-4);
  letter-spacing: -.035em;
  text-align: left;
  position: relative;
  padding-left: 0;
}

.item .body {
  padding-top: 6px;
}
.item .body h4 {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 24, "wght" 500;
  font-size: 16px;
  line-height: 24px;
  color: var(--ink);
  margin-bottom: 4px;
  letter-spacing: -.002em;
  font-weight: 500;
}
.item .body p {
  font-family: var(--font-serif);
  font-variation-settings: "opsz" 11, "wght" 400;
  font-feature-settings: "onum" 1, "pnum" 1, "ss01" 1, "liga" 1;
  font-size: 12.5px;
  line-height: 24px;
  color: var(--ink-2);
  -webkit-hanging-punctuation: first;
  hanging-punctuation: first;
}
.item .body p strong {
  color: var(--ink);
  font-weight: 500;
}

.card.many .item {
  padding: 12px 0;
  grid-template-columns: 72px 1fr;
  gap: 20px;
}
.card.many .item .num { font-size: 52px; }
.card.many .item .body h4 { font-size: 14.5px; line-height: 22px; }
.card.many .item .body p { font-size: 12px; line-height: 22px; }
</style>
</head>
<body>
<div class="card{% if data['items']|length > 3 %} many{% endif %}">
{% with meta_label='TAKEAWAYS', sub_left=(data['items']|length|string) + ' points', sub_right='★ ACTIONABLE', show_date=false %}
{% include 'minimal/_header.html.j2' %}
{% endwith %}

  <div class="content">
    <div class="topline">
      <div class="idx">T&nbsp;A&nbsp;K&nbsp;E&nbsp;A&nbsp;W&nbsp;A&nbsp;Y&nbsp;S</div>
      <div class="midrule"></div>
      <div class="num">03<small>OF&nbsp;05</small></div>
    </div>

    <div class="hd">
      <h2>{{ data.title | em }}</h2>
    </div>

    {% for item in data['items'] %}
    <div class="item">
      <div class="num">{{ '%02d' % loop.index }}</div>
      <div class="body">
        <h4>{{ item.title }}</h4>
        <p>{{ item.body | em }}</p>
      </div>
    </div>
    {% endfor %}
  </div>

{% include 'minimal/_footer.html.j2' %}
</div>
</body>
</html>
