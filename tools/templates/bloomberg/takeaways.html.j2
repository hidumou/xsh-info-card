<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ data.title | em | striptags | default('要点') }} · 要点</title>
<style>
{% include 'bloomberg/_base.css' %}
.content { padding: 14px 18px; }
h2 {
  font-size: 22px; font-weight: 900;
  line-height: 1.3; color: var(--fg);
  margin-bottom: 4px; font-family: var(--font-sans);
  text-shadow: -0.5px 0 0 rgba(255,0,64,.4), 0.5px 0 0 rgba(0,229,255,.4);
}
h2 em {
  background: var(--amber); color: #000;
  padding: 0 4px;
  box-shadow: 0 0 12px rgba(255,138,0,.35);
  text-shadow: none;
}
.sub-head {
  font-family: var(--font-mono);
  font-size: 10px; color: var(--dim);
  margin-bottom: 10px; letter-spacing: 1px;
}
.sub-head .amb { color: var(--amber); text-shadow: 0 0 4px rgba(255,138,0,.4); }
.sub-head .g   { color: var(--phosphor); text-shadow: 0 0 4px rgba(0,255,157,.45); }

/* Terminal data table */
.tbl {
  border: 1px solid var(--line);
  background: var(--panel);
  border-top: 2px solid var(--amber);
  border-bottom: 2px solid var(--amber);
  box-shadow: 0 0 24px rgba(255,138,0,.06), inset 0 0 40px rgba(0,0,0,.3);
}
.tbl .thead {
  display: grid;
  grid-template-columns: 44px 84px 1fr 66px;
  gap: 8px;
  background: var(--amber);
  color: #000;
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 2px;
  padding: 6px 10px;
  font-weight: 700;
  box-shadow: inset 0 0 14px rgba(255,255,255,.1);
}
.row {
  display: grid;
  grid-template-columns: 44px 84px 1fr 66px;
  gap: 8px;
  align-items: flex-start;
  border-bottom: 1px solid var(--line-2);
  padding: 10px 10px;
  transition: background .2s;
}
.row:last-child { border-bottom: none; }
.row:nth-child(even) { background: rgba(255,138,0,.04); }
.row:hover { background: rgba(255,138,0,.1); }

.row .n {
  font-family: var(--font-display);
  font-size: 20px;
  color: var(--amber);
  font-weight: 700;
  line-height: 1.1;
  text-shadow: 0 0 6px rgba(255,138,0,.55), 0 0 14px rgba(255,138,0,.2);
  font-style: italic;
}
.row .sig {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--cyan);
  letter-spacing: 1.2px;
  padding-top: 5px;
  line-height: 1.5;
  text-shadow: 0 0 4px rgba(0,229,255,.4);
}
.row .sig .pct {
  display: block;
  color: var(--phosphor);
  font-size: 10.5px;
  margin-top: 2px;
  letter-spacing: 1.5px;
  text-shadow: 0 0 5px rgba(0,255,157,.5);
}
.row .sig .bar {
  display: block;
  font-family: var(--font-mono);
  font-size: 8px;
  color: var(--amber-dim);
  letter-spacing: 0;
  margin-top: 2px;
  line-height: 1;
}
.row .sig .bar .on { color: var(--phosphor); text-shadow: 0 0 3px var(--phosphor); }
.row .body h4 {
  font-size: 14px;
  color: var(--fg);
  margin-bottom: 4px;
  font-weight: 900;
  font-family: var(--font-sans);
  line-height: 1.35;
}
.row .body p {
  font-size: 12px;
  color: #9aa3b0;
  line-height: 1.6;
  font-family: var(--font-sans);
}
.row .status {
  text-align: right;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--phosphor);
  padding-top: 5px;
  text-shadow: 0 0 5px rgba(0,255,157,.55);
}
.row .status .led {
  width: 8px; height: 8px;
  margin-right: 4px;
}

.card.many .row { padding: 7px 10px; }
.card.many .row .n { font-size: 16px; }
.card.many .row .body h4 { font-size: 12.5px; }
.card.many .row .body p { font-size: 11px; line-height: 1.5; }

.legend {
  margin-top: 12px;
  font-family: var(--font-mono);
  font-size: 9.5px;
  color: var(--dim);
  letter-spacing: 1px;
  display: flex;
  gap: 16px;
  align-items: center;
  padding: 6px 10px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-left: 2px solid var(--amber);
}
.legend .g { color: var(--phosphor); text-shadow: 0 0 4px rgba(0,255,157,.5); }
.legend .a { color: var(--amber); text-shadow: 0 0 4px rgba(255,138,0,.45); }
.legend .c { color: var(--cyan); text-shadow: 0 0 4px rgba(0,229,255,.45); }
.legend .end { margin-left: auto; color: var(--amber-dim); letter-spacing: 1.5px; }
</style>
</head>
<body>
<div class="card{% if data['items']|length > 3 %} many{% endif %}">
{% with meta_label='KEYS', sub_left='TAKEAWAYS', sub_right='ACTIONABLE', show_date=false %}
{% include 'bloomberg/_header.html.j2' %}
{% endwith %}

  <div class="content">
    <h2>{{ data.title | em }}</h2>
    <div class="sub-head">// query: <span class="amb">takeaways.all</span> &middot; rows: <span class="amb">{{ data['items']|length }}</span> &middot; <span class="g">&#9679; live</span> &middot; exec 0.012s</div>

    <div class="tbl">
      <div class="thead"><span># ID</span><span>SIG/CONF</span><span>DESCRIPTION</span><span>STATUS</span></div>
      {% for item in data['items'] %}
      {% set conf = ['HI','HI','MID','HI','MID'][loop.index0] %}
      {% set bar_on = {'HI': 5, 'MID': 3, 'LO': 2}[conf] %}
      <div class="row">
        <div class="n">{{ '%02d' % loop.index }}</div>
        <div class="sig">SIG-{{ '%02d' % loop.index }}<span class="pct">{{ conf }}</span><span class="bar">{% for i in range(5) %}{% if i < bar_on %}<span class="on">█</span>{% else %}░{% endif %}{% endfor %}</span></div>
        <div class="body"><h4>{{ item.title }}</h4><p>{{ item.body | em }}</p></div>
        <div class="status"><span class="led"></span>OK</div>
      </div>
      {% endfor %}
    </div>

    <div class="legend">
      <span><span class="led"></span><span class="g">OK</span></span>
      <span><span class="led amb"></span><span class="a">SIG</span></span>
      <span><span class="led cyan"></span><span class="c">REF</span></span>
      <span class="end">eof · {{ data['items']|length }}/{{ data['items']|length }} rows</span>
    </div>
  </div>

{% include 'bloomberg/_footer.html.j2' %}
</div>
</body>
</html>
