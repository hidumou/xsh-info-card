<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ data.title | default('延伸阅读') }} · 延伸</title>
<style>
{% include 'minimal/_base.css' %}
.content {
  padding: 36px 56px 24px;
  display: flex;
  flex-direction: column;
}

.topline {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 18px;
  align-items: baseline;
  margin-bottom: 22px;
}
.topline .idx {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: 9.5px;
  letter-spacing: .46em;
  text-transform: uppercase;
  color: var(--ink);
}
.topline .midrule { height: 0; border-top: 0.5px solid var(--hair); align-self: center; }
.topline .num {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 144, "wght" 200;
  font-feature-settings: "onum" 1, "pnum" 0, "tnum" 1, "ss01" 1, "lnum" 0;
  font-size: 42px;
  line-height: 1;
  color: var(--ink);
  letter-spacing: -.02em;
}
.topline .num small {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: .22em;
  color: var(--ink-3);
  margin-left: 8px;
  vertical-align: 4px;
}

.hd {
  padding-bottom: 14px;
  border-bottom: 0.5px solid var(--hair);
  margin-bottom: 14px;
}
h2 {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  font-size: 24px;
  line-height: 30px;
  color: var(--ink);
  letter-spacing: -.005em;
}

/* groups — §01 §02 §03 §04 degree-prefix labels */
.stack {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 14px;
}
.group {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 22px;
  align-items: baseline;
  padding: 6px 0 2px;
}
.group .g-head {
  border-top: 0.5px solid var(--hair);
  padding-top: 10px;
  display: flex;
  align-items: baseline;
  gap: 8px;
  min-height: 36px;
}
.group .g-head .sigil {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 300;
  font-feature-settings: "onum" 1, "pnum" 0, "tnum" 1, "ss01" 1;
  font-size: 18px;
  line-height: 1;
  color: var(--accent);
  letter-spacing: 0;
}
.group .g-head h4 {
  font-family: var(--font-sans);
  font-weight: 300;
  font-size: 9.5px;
  letter-spacing: .32em;
  color: var(--ink);
  text-transform: uppercase;
  margin: 0;
  line-height: 14px;
}
.group ul {
  border-top: 0.5px solid var(--hair);
  padding-top: 10px;
  padding-left: 0;
}
.group li {
  list-style: none;
  font-family: var(--font-serif);
  font-variation-settings: "opsz" 11, "wght" 400;
  font-feature-settings: "onum" 1, "pnum" 1, "ss01" 1;
  font-size: 12.5px;
  line-height: 24px;
  color: var(--ink-2);
  padding: 0 0 4px;
  -webkit-hanging-punctuation: first;
  hanging-punctuation: first;
}
.group li::before { content: ""; }
.group li .t { color: var(--ink); display: inline; }
.group li .src {
  color: var(--ink-3);
  font-variation-settings: "opsz" 9, "wght" 350;
  font-size: 10.5px;
  font-style: italic;
  display: inline;
  margin-left: 4px;
  letter-spacing: .01em;
}

/* CTA footer block */
.cta {
  margin-top: auto;
  padding-top: 18px;
  border-top: 0.5px solid var(--hair);
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 24px;
  align-items: center;
}
.cta .mark {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  font-size: 11px;
  letter-spacing: .32em;
  color: var(--ink);
  display: flex;
  align-items: center;
  gap: 10px;
  text-transform: uppercase;
}
.cta .mark img { object-fit: contain; }
.cta .c {
  font-family: var(--font-serif);
  font-variation-settings: "opsz" 11, "wght" 400;
  font-style: italic;
  font-size: 11px;
  color: var(--ink-3);
  text-align: center;
  line-height: 18px;
}
.cta .u {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  font-size: 13px;
  letter-spacing: .32em;
  color: var(--ink);
  text-transform: uppercase;
}
</style>
</head>
<body>
<div class="card">
{% with meta_label='INDEX', sub_left='Further Reading', sub_right='※ SUBSCRIBE', show_date=false %}
{% include 'minimal/_header.html.j2' %}
{% endwith %}

  <div class="content">
    <div class="topline">
      <div class="idx">F&nbsp;U&nbsp;R&nbsp;T&nbsp;H&nbsp;E&nbsp;R</div>
      <div class="midrule"></div>
      <div class="num">05<small>OF&nbsp;05</small></div>
    </div>

    <div class="hd">
      <h2>{{ data.title }}</h2>
    </div>

    <div class="stack">
    {% for g in data.groups %}
    <div class="group">
      <div class="g-head">
        <span class="sigil">§{{ '%02d' % loop.index }}</span>
        <h4>{{ g.title }}</h4>
      </div>
      <ul>
        {% for i in g['items'] %}
        <li><span class="t">{{ i.text }}</span>{% if i.src %}<span class="src">{{ i.src }}</span>{% endif %}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
    </div>

    <div class="cta">
      <div class="mark"><img src="{{ logo_uri }}" width="24" height="16" alt="SupSub">SUPSUB</div>
      <div class="c">把注意力留给有价值的内容</div>
      <div class="u">supsub.ai</div>
    </div>
  </div>

{% include 'minimal/_footer.html.j2' %}
</div>
</body>
</html>
