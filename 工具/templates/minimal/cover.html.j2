<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ data.title | em | striptags }} · 封面</title>
<style>
{% include 'minimal/_base.css' %}

/* ====== COVER — Fraunces opsz 144 hero, part-cropped ====== */
.content {
  padding: 38px 56px 22px;
  display: grid;
  grid-template-rows: 1fr auto auto;
  gap: 0;
  position: relative;
}

/* mono metadata strip :  N° 020 · 2026.04.24 · ISSUE */
.mono-strip {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: .22em;
  color: var(--ink-3);
  padding-bottom: 18px;
  display: flex;
  gap: 18px;
  align-items: center;
}
.mono-strip .dot { color: var(--ink-4); }
.mono-strip .emp { color: var(--ink); }

/* HERO — 020，完整显示不裁切 */
.hero {
  position: relative;
  height: 260px;
  margin: 0 -4px 0 -10px;
  display: block;
}
.hero .number {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 144, "wght" 200, "SOFT" 50;
  font-feature-settings: "onum" 1, "pnum" 0, "tnum" 1, "ss01" 1, "lnum" 0;
  font-size: 260px;
  line-height: 1;
  letter-spacing: -.045em;
  color: var(--ink);
  position: absolute;
  top: 0;
  left: -6px;
  white-space: nowrap;
}
.hero .edition {
  position: absolute;
  right: 0; top: 22px;
  text-align: right;
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: 9px;
  letter-spacing: .42em;
  text-transform: uppercase;
  color: var(--ink-3);
  line-height: 1.9;
}
.hero .edition .lg {
  display: block;
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  font-size: 11px;
  letter-spacing: .32em;
  color: var(--ink);
  margin-bottom: 6px;
}
.hero .edition .rule {
  display: inline-block;
  width: 18px; height: 1px;
  background: var(--accent);
  margin: 10px 0 6px;
}

/* LOWER — title + dek, right-aligned, serif */
.lower {
  padding-top: 24px;
  border-top: 0.5px solid var(--hair);
  max-width: 540px;
  margin-left: auto;
}
h1 {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  font-size: 34px;
  line-height: 42px;      /* 6px baseline */
  letter-spacing: -.01em;
  color: var(--ink);
  margin-bottom: 12px;
  text-align: right;
}
h1 em {
  font-style: normal;
  border-bottom: 0.5px solid var(--accent);
  padding-bottom: 2px;
}
.dek {
  font-family: var(--font-serif);
  font-variation-settings: "opsz" 11, "wght" 400;
  font-size: 12.5px;
  line-height: 24px;      /* 6px baseline */
  color: var(--ink-2);
  text-align: right;
}

/* FOOT — tiny source block with gold hairline box */
.foot-data {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 36px;
  align-items: end;
  padding-top: 20px;
  margin-top: 20px;
  border-top: 0.5px solid var(--hair);
}
.foot-data .src-line {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: 9px;
  letter-spacing: .34em;
  color: var(--ink-3);
  text-transform: uppercase;
  line-height: 1.6;
  position: relative;
  padding-left: 34px;
}
.foot-data .src-line::before {
  content: "";
  position: absolute; left: 0; top: 8px;
  width: 24px; height: 1px;
  background: var(--accent);
}
.foot-data .src-line .src {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 500;
  color: var(--ink);
  font-size: 14px;
  letter-spacing: .01em;
  text-transform: none;
  margin-top: 4px;
  display: block;
  line-height: 20px;
}
.foot-data .src-line .m {
  text-transform: none;
  letter-spacing: 0;
  color: var(--ink-3);
  font-family: var(--font-serif);
  font-variation-settings: "opsz" 9, "wght" 350;
  font-style: italic;
  font-size: 10px;
  line-height: 16px;
  margin-top: 3px;
  display: block;
}

.kpi-mini {
  display: flex;
  gap: 24px;
  align-items: flex-end;
}
.kpi-mini .dp { text-align: right; }
.kpi-mini .dp .k {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: 8px;
  letter-spacing: .36em;
  color: var(--ink-3);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.kpi-mini .dp .v {
  font-family: var(--font-display);
  font-variation-settings: "opsz" 60, "wght" 400;
  font-feature-settings: "onum" 1, "pnum" 1, "ss01" 1;
  font-size: 20px;
  line-height: 1;
  color: var(--ink);
  letter-spacing: -.01em;
}
.kpi-mini .dp .v.up   { color: var(--up); }
.kpi-mini .dp .v.down { color: var(--down); }
</style>
</head>
<body>
<div class="card">
{% with meta_label='DAILY', sub_left=meta.topic_tag, sub_right=(meta.rating or '★ READ'), show_date=true %}
{% include 'minimal/_header.html.j2' %}
{% endwith %}

  <div class="content">
    <div class="mono-strip">
      <span class="emp">N°&nbsp;{{ meta.issue_no }}</span>
      <span class="dot">·</span>
      <span>{{ meta.date }}</span>
      <span class="dot">·</span>
      <span>ISSUE</span>
      <span class="dot">·</span>
      <span>DAILY</span>
    </div>

    <div class="hero">
      <div class="number">{{ meta.issue_no }}</div>
      <div class="edition">
        <span class="lg">№&nbsp;{{ meta.issue_no }}</span>
        VOL&nbsp;I<br>
        MMXXVI
        <span class="rule"></span><br>
        {{ meta.date }}
      </div>
    </div>

    <div class="lower">
      <h1>{{ data.title | em }}</h1>
      <div class="dek">{{ data.dek }}</div>
    </div>

    <div class="foot-data">
      <div class="src-line">
        Source &nbsp;·&nbsp; 信号来源
        <span class="src">{{ data.source_name }}</span>
        {% if data.source_meta %}<span class="m">{{ data.source_meta }}</span>{% endif %}
      </div>
      {% if data.kpi %}
      <div class="kpi-mini">
      {% for k in data.kpi %}
        <div class="dp"><div class="k">{{ k.key }}</div><div class="v{% if k.tone %} {{ k.tone }}{% endif %}">{{ k.value }}</div></div>
      {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>

{% with disc='save your attention' %}
{% include 'minimal/_footer.html.j2' %}
{% endwith %}
</div>
</body>
</html>
