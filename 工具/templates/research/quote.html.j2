<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>金句 · {{ data.cite }}</title>
<style>
{% include 'research/_base.css' %}

.card { background-color: var(--paper); }

/* quote 卡不再走深蓝底，改走纸本 pull quote 版式 */
.quote-card {
  flex: 1;
  padding: 40px 52px 28px;
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  text-align: center;
  position: relative;
  background-color: var(--paper);
  background-image: radial-gradient(rgba(0,0,0,.02) 1px, transparent 1px);
  background-size: 2.5px 2.5px;
}

/* 双 hairline 装饰框（上下两条金线，而非整块色块） */
.quote-card::before {
  content: ""; position: absolute;
  top: 30px; left: 52px; right: 52px; height: 2px;
  background: var(--gold);
}
.quote-card::after {
  content: ""; position: absolute;
  top: 36px; left: 52px; right: 52px; height: 1px;
  background: var(--gold); opacity: .6;
}

.quote-inner {
  max-width: 560px;
  margin: auto 0;
  position: relative;
  padding-top: 40px;
}

/* 特大号引号作为水印 */
.mark {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 200px;
  line-height: .6;
  color: var(--oxblood);
  opacity: .15;
  position: absolute;
  top: -50px; left: -30px;
  font-weight: 700;
  font-variation-settings: "opsz" 144;
  user-select: none;
}

blockquote {
  font-family: var(--font-display);
  font-size: 38px; line-height: 1.38;
  font-weight: 500;
  font-style: italic;
  margin: 16px 0 28px;
  padding: 0 10px;
  color: var(--navy);
  letter-spacing: -.012em;
  font-variation-settings: "opsz" 144;
  position: relative;
}
blockquote em {
  color: var(--oxblood);
  font-style: italic;
  font-weight: 700;
  font-family: var(--font-display);
}

/* 中文走 Noto Serif SC 会自动 fallback（Fraunces 不含中文），所以不用单独写 */

.cite-rule {
  display: flex; align-items: center; justify-content: center;
  gap: 12px; margin-bottom: 10px;
}
.cite-rule::before, .cite-rule::after {
  content: ""; width: 50px; height: 1px; background: var(--gold);
}
.cite-rule .orn {
  font-family: var(--font-display);
  font-style: italic; font-size: 14px;
  color: var(--gold);
}

cite {
  font-family: var(--font-sc);
  font-style: normal;
  font-size: 11.5px;
  letter-spacing: .32em;
  color: var(--oxblood);
  text-transform: uppercase;
  display: block;
  font-weight: 700;
  margin-bottom: 4px;
}

.context {
  margin-top: 22px;
  font-family: var(--font-cn);
  font-size: 12.5px;
  color: var(--ink-2);
  line-height: 1.78;
  max-width: 460px;
  margin-left: auto; margin-right: auto;
  font-style: italic;
  text-align: left;
  padding: 14px 20px 0;
  border-top: 1px solid var(--rule);
  position: relative;
}
.context::before {
  content: "❦"; position: absolute;
  top: -11px; left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-display);
  font-size: 15px; color: var(--gold);
  background: var(--paper); padding: 0 10px;
  font-style: normal;
}
</style>
</head>
<body>
<div class="card">
{% with meta_label='Pull Quote', sub_left='Pull Quote · 重点摘抄', sub_right='★ Share', show_date=false %}
{% include 'research/_header.html.j2' %}
{% endwith %}

  <div class="quote-card">
    <div class="quote-inner">
      <div class="mark">&ldquo;</div>
      <blockquote>{{ data.text | em }}</blockquote>
      <div class="cite-rule"><span class="orn">❦</span></div>
      <cite>{{ data.cite }}</cite>
      {% if data.context %}<div class="context">{{ data.context }}</div>{% endif %}
    </div>
  </div>

{% include 'research/_footer.html.j2' %}
</div>
</body>
</html>
