<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ data.title | default('延伸阅读') }} · 延伸</title>
<style>
{% include 'wsj/_base.css' %}
.content { padding: 20px 40px 14px; }

.section-label-top {
  text-align: center;
  font-family: var(--font-condensed);
  font-weight: 500;
  font-size: 10px;
  letter-spacing: .4em;
  color: var(--red-ink);
  text-transform: uppercase;
  margin-bottom: 6px;
}
.section-label-top::before { content: "❖  "; }
.section-label-top::after  { content: "  ❖"; }

h2 {
  font-family: var(--font-masthead);
  font-size: 28px;
  font-weight: 900;
  margin-bottom: 4px;
  text-align: center;
  letter-spacing: -0.01em;
}

.sub-rule {
  text-align: center;
  font-family: var(--font-serif-alt);
  font-style: italic;
  font-size: 12.5px;
  color: var(--ink-2);
  padding-bottom: 10px;
  margin-bottom: 10px;
}

/* 单列 index 堆叠 */
.index-stack {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* 每组：顶部带 ❖ 前缀的组标题（单独一行） + items */
.group {
  padding: 6px 0 6px;
  border-bottom: 1px dashed var(--paper-edge);
}
.group:last-child { border-bottom: none; }
.group h4 {
  font-family: var(--font-masthead);
  font-style: italic;
  font-weight: 700;
  font-size: 17px;
  color: var(--ink);
  margin-bottom: 4px;
  letter-spacing: -0.005em;
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.group h4::before {
  content: "❖";
  color: var(--red-ink);
  font-size: 14px;
  font-style: normal;
}
.group ul { margin: 2px 0 0 0; padding-left: 0; }
.group li {
  list-style: none;
  font-size: 12.5px;
  line-height: 1.6;
  color: var(--ink-2);
  padding-left: 16px;
  position: relative;
  font-family: var(--font-serif);
  margin-bottom: 2px;
  text-align: left;
}
.group li::before {
  content: "—";
  position: absolute;
  left: 0;
  color: var(--red-ink);
  font-weight: 700;
}
.group li .src {
  font-family: var(--font-condensed);
  font-weight: 500;
  color: var(--ink-3);
  font-size: 10px;
  font-style: normal;
  margin-left: 6px;
  letter-spacing: .18em;
  text-transform: uppercase;
}

/* Colophon —— 纸黄底 + 细双线边框 */
.colophon {
  margin-top: 10px;
  padding: 10px 16px;
  border-top: 3px double var(--ink);
  border-bottom: 3px double var(--ink);
  text-align: center;
  font-family: var(--font-serif-alt);
  font-style: italic;
  font-size: 13px;
  color: var(--ink-2);
  background: var(--paper-2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}
.colophon img { object-fit: contain; }
.colophon strong {
  font-family: var(--font-masthead);
  font-weight: 900;
  color: var(--ink);
  font-style: italic;
  font-size: 16px;
  letter-spacing: -0.01em;
}
.colophon .url {
  display: block;
  margin-top: 2px;
  font-family: var(--font-condensed);
  font-weight: 600;
  font-size: 10.5px;
  letter-spacing: .4em;
  color: var(--red-ink);
  font-style: normal;
  text-transform: uppercase;
}
</style>
</head>
<body>
<div class="card">
{% with meta_label='FURTHER', sub_left='INDEX · 延伸资源', sub_right='※ SUBSCRIBE', show_date=false %}
{% include 'wsj/_header.html.j2' %}
{% endwith %}

  <div class="content">
    <div class="section-label-top">THE INDEX &middot; 延伸阅读</div>
    <h2>{{ data.title }}</h2>
    <div class="sub-rule">— continue reading on supsub.ai —</div>

    <div class="index-stack">
    {% for g in data.groups %}
    <div class="group">
      <h4>{{ g.title }}</h4>
      <ul>
        {% for i in g['items'] %}
        <li>{{ i.text }}{% if i.src %}<span class="src">{{ i.src }}</span>{% endif %}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
    </div>

    <div class="colophon">
      <img src="{{ logo_uri }}" width="40" height="26" alt="SupSub">
      <div><strong>Sup&middot;Sub Daily</strong> — 把注意力留给有价值的内容<span class="url">supsub.ai</span></div>
    </div>
  </div>

{% include 'wsj/_footer.html.j2' %}
</div>
</body>
</html>
