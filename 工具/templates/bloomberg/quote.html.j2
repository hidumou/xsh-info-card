<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>金句 · {{ data.cite }}</title>
<style>
{% include 'bloomberg/_base.css' %}
.content { padding: 14px 18px; display: flex; flex-direction: column; }

.log-head {
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--phosphor);
  margin-bottom: 6px;
  letter-spacing: 1px;
  text-shadow: 0 0 5px rgba(0,255,157,.5);
}
.log-head .amb { color: var(--amber); text-shadow: 0 0 5px rgba(255,138,0,.45); }
.log-head .c { color: var(--cyan); text-shadow: 0 0 5px rgba(0,229,255,.45); }

/* ASCII-character frame (literal dashes) */
.ascii-top, .ascii-bot {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--amber);
  letter-spacing: 0;
  white-space: pre;
  text-align: center;
  line-height: 1;
  text-shadow: 0 0 6px rgba(255,138,0,.55);
  margin: 2px 0;
}
.ascii-top { margin-top: 4px; }
.ascii-bot { margin-bottom: 2px; }

.quote-box {
  margin: 0;
  padding: 18px 24px 22px;
  background:
    radial-gradient(ellipse at center, rgba(255,138,0,.08), transparent 70%),
    var(--panel);
  position: relative;
  flex: 1;
  display: flex; flex-direction: column; justify-content: center;
  border-left: 1px solid var(--amber-dim);
  border-right: 1px solid var(--amber-dim);
}

/* Giant ASCII quote mark */
.big-quote {
  font-family: var(--font-display);
  font-size: 160px;
  font-weight: 700;
  font-style: italic;
  line-height: 0.6;
  color: var(--phosphor);
  text-shadow:
    0 0 12px rgba(0,255,157,.65),
    0 0 28px rgba(0,255,157,.35),
    0 0 60px rgba(0,255,157,.2);
  margin: 0 0 6px -6px;
  letter-spacing: -8px;
}
.big-quote-close {
  font-family: var(--font-display);
  font-size: 110px;
  font-weight: 700;
  font-style: italic;
  line-height: 0.6;
  color: var(--phosphor);
  text-shadow: 0 0 10px rgba(0,255,157,.55), 0 0 24px rgba(0,255,157,.3);
  text-align: right;
  margin-top: 10px;
  letter-spacing: -6px;
}

blockquote {
  font-size: 28px;
  line-height: 1.48;
  font-weight: 700;
  color: var(--fg);
  padding: 0;
  font-family: var(--font-sans);
  text-shadow: -0.4px 0 0 rgba(255,0,64,.35), 0.4px 0 0 rgba(0,229,255,.35);
}
blockquote em {
  color: var(--amber);
  background: rgba(255,138,0,.16);
  padding: 0 5px;
  box-shadow: 0 0 14px rgba(255,138,0,.35);
  text-shadow: 0 0 8px rgba(255,138,0,.55);
}

cite {
  margin-top: 18px;
  font-family: var(--font-mono);
  font-style: normal;
  font-size: 11px;
  letter-spacing: 3px;
  color: var(--cyan);
  text-transform: uppercase;
  display: block;
  padding-top: 10px;
  border-top: 1px dashed var(--line-2);
  text-shadow: 0 0 5px rgba(0,229,255,.45);
}
cite::before { content: "// author: "; color: var(--amber); text-shadow: 0 0 4px rgba(255,138,0,.4); }

.context {
  margin-top: 10px;
  font-size: 12px;
  color: #9aa3b0;
  line-height: 1.7;
  font-family: var(--font-sans);
  padding: 8px 0 0;
}
.context::before {
  content: "# ctx: ";
  color: var(--cyan);
  font-family: var(--font-mono);
  font-size: 10.5px;
  text-shadow: 0 0 4px rgba(0,229,255,.4);
}

.log-foot {
  margin-top: 10px;
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--dim);
  letter-spacing: 1px;
  display: flex; justify-content: space-between;
}
.log-foot .g { color: var(--phosphor); text-shadow: 0 0 4px rgba(0,255,157,.5); }
.log-foot .a { color: var(--amber); text-shadow: 0 0 4px rgba(255,138,0,.45); }
</style>
</head>
<body>
<div class="card">
{% with meta_label='PULL', sub_left='QUOTE', sub_right='SHARE', show_date=false %}
{% include 'bloomberg/_header.html.j2' %}
{% endwith %}

  <div class="content">
    <div class="log-head">&gt; <span class="amb">load</span> quote.sig &middot; <span class="c">#{{ meta.issue_no }}</span> &middot; ready<span class="caret">▌</span></div>

    <div class="ascii-top">┌────────── PULL QUOTE · SIG #{{ meta.issue_no }} ──────────┐</div>
    <div class="quote-box">
      <div class="big-quote">&ldquo;</div>
      <blockquote>{{ data.text | em }}</blockquote>
      <div class="big-quote-close">&rdquo;</div>
      <cite>{{ data.cite }}</cite>
      {% if data.context %}<div class="context">{{ data.context }}</div>{% endif %}
    </div>
    <div class="ascii-bot">└────────── END · {{ '%02d' % page_no }}/{{ '%02d' % total_pages }} ──────────┘</div>

    <div class="log-foot">
      <span><span class="g">[OK]</span> quote rendered &middot; buffer=CRT-BUF-2</span>
      <span><span class="a">share</span> via supsub.ai</span>
    </div>
  </div>

{% include 'bloomberg/_footer.html.j2' %}
</div>
</body>
</html>
